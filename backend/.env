# Base de données
DATABASE_URL=postgresql://geoportail_user:geoportail_pass_2024@localhost:5432/geoportail

# Sécurité JWT  (change cette clé avant déploiement !)
SECRET_KEY=change_this_to_a_random_64_char_string_before_production

# CORS — ajoute ton URL Vercel quand tu déploies
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Email alertes  (Gmail recommandé)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[INSÉRER TON EMAIL GMAIL]
SMTP_PASSWORD=[INSÉRER MOT DE PASSE APPLICATION GMAIL]
EMAIL_FROM=serres@agrobiotech.ma

# IoT API
IOT_BASE_URL=http://guardian.pro-leaf.com:8083/wx/android/behive

# Environnement
ENV=development
